# Copy this file to .streamlit/secrets.toml (same folder) and fill in your
# real Supabase connection string. secrets.toml itself is excluded by
# .gitignore, so your real database password never gets pushed to GitHub.
#
# Where to get this: Supabase dashboard -> your project -> Settings -> Database
# -> "Connection string" -> URI tab. Copy it, then replace [YOUR-PASSWORD]
# with the database password you set when creating the project.

DATABASE_URL = "postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres"
